@page "/"
@rendermode InteractiveServer
@attribute [Authorize]
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<AppDbContext> DbFactory

<PageTitle>Tableau de bord · kernelMK</PageTitle>

<div class="mb-6 flex items-center justify-between">
    <div>
        <h1>Tableau de bord</h1>
        <p class="text-sm text-slate-500 mt-1">Vue d'ensemble de l'automatisation et de la supervision des jobs.</p>
    </div>
    <a href="jobs/new" class="kmk-btn-primary">
        <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /></svg>
        Nouveau job
    </a>
</div>

@if (_loading)
{
    <p class="text-slate-500 text-sm">Chargement...</p>
}
else
{
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4 mb-6">
        <div class="kmk-stat-card">
            <span class="kmk-stat-label">Jobs actifs</span>
            <span class="kmk-stat-value">@_activeJobs</span>
        </div>
        <div class="kmk-stat-card">
            <span class="kmk-stat-label">Jobs inactifs</span>
            <span class="kmk-stat-value text-slate-400">@_inactiveJobs</span>
        </div>
        <div class="kmk-stat-card">
            <span class="kmk-stat-label">En cours</span>
            <span class="kmk-stat-value text-amber-500">@_runningCount</span>
        </div>
        <div class="kmk-stat-card">
            <span class="kmk-stat-label">Réussis (24h)</span>
            <span class="kmk-stat-value text-emerald-600">@_successCount</span>
        </div>
        <div class="kmk-stat-card">
            <span class="kmk-stat-label">Échoués (24h)</span>
            <span class="kmk-stat-value text-red-600">@_failedCount</span>
        </div>
    </div>

    <p class="text-sm text-slate-500 mb-6">
        Durée moyenne des traitements (24h) : <span class="font-medium text-slate-800">@_avgDurationSeconds.ToString("F1") s</span>
    </p>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <div class="kmk-card">
            <div class="kmk-card-header">Prochaines exécutions planifiées</div>
            <div class="kmk-card-body overflow-x-auto">
                @if (_upcoming.Count == 0)
                {
                    <p class="text-sm text-slate-400">Aucune exécution planifiée.</p>
                }
                else
                {
                    <table>
                        <thead><tr><th>Job</th><th>Déclencheur</th><th>Prochaine exécution</th></tr></thead>
                        <tbody>
                            @foreach (var t in _upcoming)
                            {
                                <tr>
                                    <td class="font-medium text-slate-700">@t.Job?.Name</td>
                                    <td class="text-slate-500">@t.Type</td>
                                    <td class="text-slate-500">@t.NextRunAt?.ToLocalTime().ToString("g")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>

        <div class="kmk-card">
            <div class="kmk-card-header">Derniers incidents</div>
            <div class="kmk-card-body overflow-x-auto">
                @if (_recentIncidents.Count == 0)
                {
                    <p class="text-sm text-slate-400">Aucun incident récent.</p>
                }
                else
                {
                    <table>
                        <thead><tr><th>Job</th><th>Statut</th><th>Début</th><th>Message</th></tr></thead>
                        <tbody>
                            @foreach (var e in _recentIncidents)
                            {
                                <tr>
                                    <td><a href="@($"executions/{e.Id}")" class="font-medium">@e.Job?.Name</a></td>
                                    <td><span class="kmk-badge-danger">@e.Status</span></td>
                                    <td class="text-slate-500">@e.StartedAt.ToLocalTime().ToString("g")</td>
                                    <td class="text-slate-500 truncate max-w-xs">@e.Message</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>
}

@code {
    private bool _loading = true;
    private int _activeJobs, _inactiveJobs, _runningCount, _successCount, _failedCount;
    private double _avgDurationSeconds;
    private List<JobTrigger> _upcoming = new();
    private List<JobExecution> _recentIncidents = new();

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();

        _activeJobs = await db.Jobs.CountAsync(j => j.Enabled);
        _inactiveJobs = await db.Jobs.CountAsync(j => !j.Enabled);
        _runningCount = await db.JobExecutions.CountAsync(e => e.Status == JobStatus.EnCours);

        var since = DateTime.UtcNow.AddHours(-24);
        var recent = db.JobExecutions.Where(e => e.StartedAt >= since && e.FinishedAt != null);
        _successCount = await recent.CountAsync(e => e.Status == JobStatus.Succes);
        _failedCount = await recent.CountAsync(e => e.Status == JobStatus.Echec);

        var timestamps = await recent.Select(e => new { e.StartedAt, e.FinishedAt }).ToListAsync();
        _avgDurationSeconds = timestamps.Count > 0
            ? timestamps.Average(t => (t.FinishedAt!.Value - t.StartedAt).TotalSeconds)
            : 0;

        _upcoming = await db.JobTriggers
            .Include(t => t.Job)
            .Where(t => t.Enabled && t.NextRunAt != null && t.Job!.Enabled)
            .OrderBy(t => t.NextRunAt)
            .Take(10)
            .ToListAsync();

        _recentIncidents = await db.JobExecutions
            .Include(e => e.Job)
            .Where(e => e.Status == JobStatus.Echec)
            .OrderByDescending(e => e.StartedAt)
            .Take(10)
            .ToListAsync();

        _loading = false;
    }
}
