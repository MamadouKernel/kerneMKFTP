@page "/credentials"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Administrateur,Developpeur")]
@using Microsoft.EntityFrameworkCore
@using KernelMK.Data.Security
@using KernelMK.Engine.Audit
@inject IDbContextFactory<AppDbContext> DbFactory
@inject CredentialProtector Protector
@inject AuditService Audit
@inject AuthenticationStateProvider AuthState

<PageTitle>Credentials · kernelMK</PageTitle>

<h1>Coffre-fort de credentials</h1>
<p class="text-sm text-slate-500 mt-1 mb-6">Les secrets sont chiffrés (ASP.NET Data Protection) avant stockage — jamais affichés en clair après création.</p>

<div class="kmk-card mb-6">
    <div class="kmk-card-body">
        <EditForm Model="_newCredential" OnValidSubmit="AddAsync">
            <div class="grid grid-cols-2 sm:grid-cols-6 gap-3 items-end">
                <div><label class="kmk-label">Nom</label><InputText class="kmk-input" @bind-Value="_newCredential.Name" /></div>
                <div>
                    <label class="kmk-label">Type</label>
                    <InputSelect class="kmk-select" @bind-Value="_newCredential.Type">
                        @foreach (var t in Enum.GetValues<CredentialType>())
                        {
                            <option value="@t">@t</option>
                        }
                    </InputSelect>
                </div>
                <div><label class="kmk-label">Utilisateur</label><InputText class="kmk-input" @bind-Value="_newCredential.Username" /></div>
                <div><label class="kmk-label">Hôte</label><InputText class="kmk-input" @bind-Value="_newCredential.Host" /></div>
                <div><label class="kmk-label">Secret (mot de passe / clé)</label><InputText type="password" class="kmk-input" @bind-Value="_plainSecret" /></div>
                <div><button type="submit" class="kmk-btn-primary w-full">Ajouter</button></div>
            </div>
        </EditForm>
    </div>
</div>

@if (_loading)
{
    <p class="text-sm text-slate-500">Chargement...</p>
}
else
{
    <div class="kmk-card overflow-x-auto">
        <table>
            <thead><tr><th>Nom</th><th>Type</th><th>Utilisateur</th><th>Hôte</th><th>Créé le</th><th></th></tr></thead>
            <tbody>
                @foreach (var c in _credentials)
                {
                    <tr>
                        <td class="font-medium">@c.Name</td>
                        <td class="text-slate-500">@c.Type</td>
                        <td class="text-slate-500">@c.Username</td>
                        <td class="text-slate-500">@c.Host</td>
                        <td class="text-slate-500">@c.CreatedAt.ToLocalTime().ToString("g")</td>
                        <td><button class="kmk-btn-danger kmk-btn-sm" @onclick="() => DeleteAsync(c)">Supprimer</button></td>
                    </tr>
                }
                @if (_credentials.Count == 0)
                {
                    <tr><td colspan="6" class="text-center text-slate-400 py-8">Aucun credential enregistré.</td></tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private List<Credential> _credentials = new();
    private bool _loading = true;
    private Credential _newCredential = new();
    private string _plainSecret = "";
    private string? _currentUser;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthState.GetAuthenticationStateAsync();
        _currentUser = authState.User.Identity?.Name;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        await using var db = await DbFactory.CreateDbContextAsync();
        _credentials = await db.Credentials.OrderBy(c => c.Name).ToListAsync();
        _loading = false;
    }

    private async Task AddAsync()
    {
        if (string.IsNullOrWhiteSpace(_newCredential.Name) || string.IsNullOrWhiteSpace(_plainSecret)) return;

        _newCredential.EncryptedSecret = Protector.Protect(_plainSecret);
        _newCredential.CreatedBy = _currentUser;

        await using var db = await DbFactory.CreateDbContextAsync();
        db.Credentials.Add(_newCredential);
        await db.SaveChangesAsync();
        await Audit.LogAsync(AuditAction.Creation, nameof(Credential), _newCredential.Id.ToString(), _newCredential.Name, null, _currentUser);

        _newCredential = new Credential();
        _plainSecret = "";
        await LoadAsync();
    }

    private async Task DeleteAsync(Credential c)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.Credentials.FindAsync(c.Id);
        if (entity is null) return;
        db.Credentials.Remove(entity);
        await db.SaveChangesAsync();
        await Audit.LogAsync(AuditAction.Suppression, nameof(Credential), c.Id.ToString(), c.Name, null, _currentUser);
        await LoadAsync();
    }
}
