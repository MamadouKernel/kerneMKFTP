@implements IDisposable
@inject NavigationManager NavigationManager

<input type="checkbox" id="kmk-nav-toggle" class="peer hidden" />

<label for="kmk-nav-toggle"
       class="peer-checked:block hidden fixed inset-0 z-30 bg-slate-900/40 lg:hidden"></label>

<aside class="fixed inset-y-0 left-0 z-40 w-64 -translate-x-full peer-checked:translate-x-0 transition-transform duration-200
              lg:translate-x-0 lg:static lg:z-auto flex flex-col bg-slate-900 text-slate-300">

    <div class="flex items-center gap-2.5 px-5 h-16 border-b border-slate-800 shrink-0">
        <div class="h-8 w-8 rounded-lg bg-brand-600 flex items-center justify-center text-white font-bold text-sm">K</div>
        <span class="text-white font-semibold tracking-tight text-lg">kernel<span class="text-brand-400">MK</span></span>
    </div>

    <AuthorizeView>
        <Authorized>
            <nav class="flex-1 overflow-y-auto px-3 py-4 space-y-0.5">
                <a href="" class="@(IsActive("", true) ? "kmk-nav-link-active" : "kmk-nav-link")">
                    <svg class="h-5 w-5 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75A2.25 2.25 0 0 1 6 4.5h2.25a2.25 2.25 0 0 1 2.25 2.25V9A2.25 2.25 0 0 1 8.25 11.25H6A2.25 2.25 0 0 1 3.75 9V6.75ZM3.75 15.75A2.25 2.25 0 0 1 6 13.5h2.25a2.25 2.25 0 0 1 2.25 2.25V18a2.25 2.25 0 0 1-2.25 2.25H6A2.25 2.25 0 0 1 3.75 18v-2.25ZM13.5 6.75a2.25 2.25 0 0 1 2.25-2.25H18a2.25 2.25 0 0 1 2.25 2.25V9A2.25 2.25 0 0 1 18 11.25h-2.25A2.25 2.25 0 0 1 13.5 9V6.75ZM13.5 15.75a2.25 2.25 0 0 1 2.25-2.25H18a2.25 2.25 0 0 1 2.25 2.25V18A2.25 2.25 0 0 1 18 20.25h-2.25A2.25 2.25 0 0 1 13.5 18v-2.25Z" /></svg>
                    Tableau de bord
                </a>
                <a href="jobs" class="@(IsActive("jobs", false) ? "kmk-nav-link-active" : "kmk-nav-link")">
                    <svg class="h-5 w-5 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6"><path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.324.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 0 1 1.37.49l1.296 2.247a1.125 1.125 0 0 1-.26 1.431l-1.003.827c-.293.24-.438.613-.431.992a6.759 6.759 0 0 1 0 .255c-.007.378.138.75.43.99l1.005.828c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 0 1-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.57 6.57 0 0 1-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 0 1-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 0 1-1.369-.49l-1.297-2.247a1.125 1.125 0 0 1 .26-1.431l1.004-.827c.292-.24.437-.613.43-.992a6.932 6.932 0 0 1 0-.255c.007-.378-.138-.75-.43-.99l-1.004-.828a1.125 1.125 0 0 1-.26-1.43l1.297-2.247a1.125 1.125 0 0 1 1.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128.332-.183.582-.495.644-.869l.214-1.28Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" /></svg>
                    Jobs
                </a>
                <a href="executions" class="@(IsActive("executions", false) ? "kmk-nav-link-active" : "kmk-nav-link")">
                    <svg class="h-5 w-5 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6l4 2M3.284 9A8.25 8.25 0 1 1 3 12" /></svg>
                    Historique
                </a>

                <AuthorizeView Roles="Administrateur,Developpeur" Context="devContext">
                    <a href="credentials" class="@(IsActive("credentials", false) ? "kmk-nav-link-active" : "kmk-nav-link")">
                        <svg class="h-5 w-5 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6"><path stroke-linecap="round" stroke-linejoin="round" d="m15.75 5.25 3 3m-3-3-9.53 9.53a2.121 2.121 0 0 0 0 3 2.121 2.121 0 0 0 3 0l.72-.72m5.81-11.81a3 3 0 1 1 4.243 4.243m-4.243-4.243 4.243 4.243m0 0-3.585 3.586" /></svg>
                        Credentials
                    </a>
                </AuthorizeView>
                <AuthorizeView Roles="Administrateur" Context="adminContext">
                    <a href="users" class="@(IsActive("users", false) ? "kmk-nav-link-active" : "kmk-nav-link")">
                        <svg class="h-5 w-5 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" /></svg>
                        Utilisateurs &amp; rôles
                    </a>
                    <a href="backup" class="@(IsActive("backup", false) ? "kmk-nav-link-active" : "kmk-nav-link")">
                        <svg class="h-5 w-5 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6"><path stroke-linecap="round" stroke-linejoin="round" d="M12 16.5V9.75m0 6.75-3-3m3 3 3-3M6.75 19.5a4.5 4.5 0 0 1-1.41-8.775 5.25 5.25 0 0 1 10.233-2.33 3 3 0 0 1 3.758 3.848A3.752 3.752 0 0 1 18 19.5H6.75Z" /></svg>
                        Sauvegarde
                    </a>
                </AuthorizeView>
                <AuthorizeView Roles="Administrateur,Auditeur" Context="auditContext">
                    <a href="audit" class="@(IsActive("audit", false) ? "kmk-nav-link-active" : "kmk-nav-link")">
                        <svg class="h-5 w-5 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75M3.75 6.75h16.5M3.75 6.75v10.5A2.25 2.25 0 0 0 6 19.5h12a2.25 2.25 0 0 0 2.25-2.25V6.75m-16.5 0A2.25 2.25 0 0 1 6 4.5h12a2.25 2.25 0 0 1 2.25 2.25" /></svg>
                        Audit
                    </a>
                </AuthorizeView>
            </nav>

            <div class="border-t border-slate-800 p-3 space-y-0.5">
                <a href="Account/Manage" class="kmk-nav-link">
                    <span class="h-6 w-6 shrink-0 rounded-full bg-slate-700 flex items-center justify-center text-[11px] font-semibold text-white">
                        @(context.User.Identity?.Name?.Substring(0, 1).ToUpper())
                    </span>
                    <span class="truncate">@context.User.Identity?.Name</span>
                </a>
                <form action="Account/Logout" method="post">
                    <AntiforgeryToken />
                    <input type="hidden" name="ReturnUrl" value="@currentUrl" />
                    <button type="submit" class="kmk-nav-link w-full text-left">
                        <svg class="h-5 w-5 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0 0 13.5 3h-6a2.25 2.25 0 0 0-2.25 2.25v13.5A2.25 2.25 0 0 0 7.5 21h6a2.25 2.25 0 0 0 2.25-2.25V15M12 9l3 3m0 0-3 3m3-3H2.25" /></svg>
                        Déconnexion
                    </button>
                </form>
            </div>
        </Authorized>
        <NotAuthorized>
            <nav class="flex-1 px-3 py-4">
                <a href="Account/Login" class="kmk-nav-link">
                    <svg class="h-5 w-5 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0 0 13.5 3h-6a2.25 2.25 0 0 0-2.25 2.25v13.5A2.25 2.25 0 0 0 7.5 21h6a2.25 2.25 0 0 0 2.25-2.25V15M21 12H10.5m0 0 3-3m-3 3 3 3" /></svg>
                    Connexion
                </a>
            </nav>
        </NotAuthorized>
    </AuthorizeView>
</aside>

@code {
    private string? currentUrl;

    protected override void OnInitialized()
    {
        currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        currentUrl = NavigationManager.ToBaseRelativePath(e.Location);
        StateHasChanged();
    }

    public void Dispose() => NavigationManager.LocationChanged -= OnLocationChanged;

    private bool IsActive(string href, bool exact)
    {
        var path = currentUrl?.TrimEnd('/') ?? "";
        var target = href.TrimEnd('/');
        return exact ? path == target : path == target || path.StartsWith(target + "/");
    }
}
