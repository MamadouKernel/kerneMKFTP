@inherits LayoutComponentBase

<div class="min-h-screen flex bg-slate-50">
    <NavMenu />

    <div class="flex-1 min-w-0 flex flex-col">
        <header class="h-14 border-b border-slate-200 bg-white flex items-center justify-end px-6 lg:hidden">
            <label for="kmk-nav-toggle" class="cursor-pointer text-slate-500 hover:text-slate-700">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
                </svg>
            </label>
        </header>

        <main class="flex-1 px-4 py-6 sm:px-6 lg:px-8 max-w-7xl w-full mx-auto">
            @Body
        </main>
    </div>
</div>

<div id="blazor-error-ui" data-nosnippet
     class="hidden fixed bottom-4 right-4 z-50 rounded-lg bg-slate-900 text-white text-sm px-4 py-3 shadow-lg">
    Une erreur inattendue s'est produite.
    <a href="." class="reload underline ml-1">Recharger</a>
    <span class="dismiss cursor-pointer ml-2">✕</span>
</div>
